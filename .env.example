# Public hostname for Alternator (DynamoDB API).
# Point a DNS A/AAAA record at your Coolify server, then set this to that hostname.
SCYLLA_HOST=dynamodb.example.com

# Alternator authentication (disabled by default).
# ALTERNATOR_AUTH_ENABLED=true  — reject unsigned/invalid requests (requires CQL roles).
# ALTERNATOR_AUTH_WARN=true     — log auth failures without blocking (use before enabling).
ALTERNATOR_AUTH_ENABLED=false
ALTERNATOR_AUTH_WARN=false

# Admin UI sidecar (scylla-admin service)
ADMIN_UI_HOST=admin.dynamodb.example.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Optional — only for clusters that already had a cassandra password before this stack:
# SCYLLA_CQL_PASSWORD=       set once; saved automatically to admin-secrets volume

# Optional (advanced):
# ADMIN_PASSWORD_HASH=
# SESSION_SECRET=
